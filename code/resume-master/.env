
FONTCONFIG_PATH=/var/task/fonts

# Enable server-managed AI mode:
# true  = frontend does not require manual API key input
# false = users configure AI keys in browser settings
VITE_SERVER_MANAGED_AI=false

# Optional server-side AI defaults (configure when VITE_SERVER_MANAGED_AI=true)
DEFAULT_AI_MODEL=openai
# OPENAI_API_KEY=
OPENAI_API_ENDPOINT=https://api.openai.com/v1
# OPENAI_MODEL_ID=gpt-4o-mini
# DEEPSEEK_API_KEY=
# DOUBAO_API_KEY=
# DOUBAO_MODEL_ID=
# GEMINI_API_KEY=
# GEMINI_MODEL_ID=gemini-flash-latest
